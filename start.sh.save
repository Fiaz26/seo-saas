nano 
~/seo-saas/start.sh#!/data/data/com.termux/files/usr/bin/bash

cd ~/seo-saas

echo "🚀 Starting SaaS Backend..."

# kill old processes
pkill -f uvicorn
pkill -f cloudflared

# start backend in background
nohup python -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000 > backend.log 2>&1 &

sleep 3

echo "🌐 Starting Tunnel..."

# start tunnel
nohup cloudflared tunnel --url http://127.0.0.1:8000 > tunnel.log 2>&1 &

echo "✅ SaaS Started"
echo "Check tunnel output below:"
tail -f tunnel.log
